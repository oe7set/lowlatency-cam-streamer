# MediaMTX configuration template.
# entrypoint.sh substitutes ${VAR} with envsubst before launching mediamtx.

logLevel: info
logDestinations: [stdout]

# Disable APIs we don't expose. Less surface area, fewer ports to map.
api: no
metrics: no
playback: no
hls: no
rtmp: no
srt: no

###############################################################################
# RTSP loopback ingest from GStreamer.
# Bound to 127.0.0.1 inside the container - never reachable from outside.
###############################################################################
rtsp: yes
rtspTransports: [tcp]
rtspAddress: 127.0.0.1:8554
rtspAuthMethods: [basic]

###############################################################################
# WebRTC / WHEP egress to browsers.
###############################################################################
webrtc: yes
webrtcAddress: :${WHEP_PORT}
webrtcEncryption: no
webrtcAllowOrigins: ['*']
webrtcTrustedProxies: []

# ICE candidate strategy.
# entrypoint.sh fills ICE_HOST_CANDIDATE_LIST with either the auto-detected
# default-route IP or the operator-supplied list (Tailscale, multiple LANs,
# ...) and sets ICE_USE_INTERFACES=no so mediamtx ONLY announces those
# explicit hosts. Otherwise (no list, no detection) it falls back to
# enumerating every interface, which makes browsers waste their ICE
# connectivity-check budget on docker-bridge / APIPA / loopback IPs.
webrtcLocalUDPAddress: :8189
webrtcLocalTCPAddress: :8189
webrtcIPsFromInterfaces: ${ICE_USE_INTERFACES}
webrtcIPsFromInterfacesList: []
webrtcAdditionalHosts: [${ICE_HOST_CANDIDATE_LIST}]
webrtcICEServers2:
${WEBRTC_ICE_SERVERS_BLOCK}

###############################################################################
# Per-path settings. The single path receives the GStreamer push and serves
# WHEP at /${STREAM_NAME}/whep.
###############################################################################
pathDefaults:
  # Authenticate the local GStreamer push so a stray RTSP client on the host
  # network can't hijack the path. Read-side stays open (browsers don't auth).
  source: publisher
  sourceOnDemand: no

paths:
  ${STREAM_NAME}:

authMethod: internal
authInternalUsers:
  - user: any
    pass:
    ips: []
    permissions:
      - action: read
      - action: playback
  - user: ${RTSP_USER}
    pass: ${RTSP_PASS}
    ips: [127.0.0.1/32]
    permissions:
      - action: publish
        path: ${STREAM_NAME}
